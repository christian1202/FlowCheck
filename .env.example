# Supabase Config
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database URL (for Drizzle migrations)
# Replace with the connection string for your Postgres database
DATABASE_URL="postgresql://postgres:password@localhost:5432/flowcheck"

# Brevo API Key
BREVO_API_KEY="xkeysib-your-brevo-api-key"

# Google Service Account (JSON stringified or base64)
# Contains the private key for Google Sheets & Drive API access
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS='{"type":"service_account","project_id":"..."}'

# Internal API Secret for Cron jobs (if not using Cloudflare native cron triggers exclusively)
CRON_SECRET="your-secure-random-string"
